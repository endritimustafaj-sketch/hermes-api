# Shabllon për variabla mjedisi
# Kopjoje në `.env` dhe modifiko vlerat sipas nevojës.
# Variablat e papërcaktuara këtu marrin default-et nga core/config.py

# Aplikacioni
APP_NAME="Hermes Marketplace API"
DEBUG=true

# Database
# SQLite (default):
DATABASE_URL="sqlite:///./hermes.db"
# MySQL alternative:
# DATABASE_URL="mysql+pymysql://user:pass@localhost:3306/hermes"
# PostgreSQL alternative:
# DATABASE_URL="postgresql+psycopg2://user:pass@localhost:5432/hermes"
